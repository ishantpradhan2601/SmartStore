{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend: Install Dependencies",
            "type": "shell",
            "command": "cd server && npm install",
            "problemMatcher": []
        },
        {
            "label": "Frontend: Install Dependencies",
            "type": "shell",
            "command": "cd client && npm install",
            "problemMatcher": []
        },
        {
            "label": "Database: Seed Data",
            "type": "shell",
            "command": "cd server && npm run seed",
            "problemMatcher": []
        },
        {
            "label": "Backend: Start Server (Dev Mode)",
            "type": "shell",
            "command": "cd server && npm run dev",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "Server running",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Server running"
                }
            }
        },
        {
            "label": "Frontend: Start Dev Server",
            "type": "shell",
            "command": "cd client && npm run dev",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "VITE",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Local:"
                }
            }
        },
        {
            "label": "Frontend: Build for Production",
            "type": "shell",
            "command": "cd client && npm run build",
            "problemMatcher": []
        },
        {
            "label": "Lint: Check Code",
            "type": "shell",
            "command": "cd client && npm run lint",
            "problemMatcher": []
        }
    ]
}