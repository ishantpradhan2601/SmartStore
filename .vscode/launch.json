{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend - Node.js",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/server/server.js",
            "restart": true,
            "runtimeArgs": [
                "--inspect=9229"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/server",
            "env": {
                "NODE_ENV": "development"
            },
            "protocol": "inspector"
        },
        {
            "name": "Backend - Attach to Process",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Frontend - Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/client/src",
            "sourceMaps": true,
            "runtimeArgs": [
                "--disable-background-timer-throttling"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Full Stack",
            "configurations": [
                "Backend - Node.js",
                "Frontend - Chrome"
            ],
            "stopAll": true
        }
    ]
}